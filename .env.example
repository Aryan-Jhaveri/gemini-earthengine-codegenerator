# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# --- Google (required) ---
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CLOUD_PROJECT=your-gcp-project-id-here
# https://aistudio.google.com/app/apikey

# --- Anthropic (required for Coder + Synthesizer) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# https://console.anthropic.com/

# --- MuleRouter (for Qwen — use your MuleRouter credits here) ---
MULEROUTER_API_KEY=your-mulerouter-api-key-here
MULEROUTER_BASE_URL=https://api.mulerouter.ai
# https://console.mulerouter.ai — open the API Keys tab and click Generate new key
# Used for: Coder fallback (qwen3-coder), Supervisor, Validator when Qwen credits available

# --- Model overrides (optional — change per-role model without touching code) ---
# MODEL_SUPERVISOR=gemini/gemini-2.5-flash
# MODEL_RESEARCHER=gemini/gemini-2.5-pro
# MODEL_CODER=anthropic/claude-sonnet-4-5
# MODEL_VALIDATOR=gemini/gemini-2.5-flash
# MODEL_SYNTHESIZER=anthropic/claude-haiku-4-5
# MODEL_CHAT=gemini/gemini-2.5-flash
# To route Coder through MuleRouter Qwen instead:
# MODEL_CODER=mulerouter/qwen3-coder

# --- Earth Engine service account (Phase 4 — map tile embedding) ---
# EE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# EE_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json

